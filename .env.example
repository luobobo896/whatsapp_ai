HTTP_HOST=127.0.0.1
PORT=8790
DATABASE_URL=postgres://user:password@127.0.0.1:5432/whatsapp_ai?sslmode=disable
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
COOKIE_SECURE=true
INTERNAL_API_TOKEN=your-random-token-here
# 每个 RAG MCP 进程必须设置；一个进程绑定一个 WhatsApp 账号
# 账号 ID 从创建账号的 API 响应（POST /api/accounts）或 Web 界面账号列表获取
# 格式为 24 位十六进制字符串（UUID）
WHATSAPP_AI_ACCOUNT_ID=replace-with-a-whatsapp-account-id
